{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"noEmit": true,
		"paths": {
			"@": ["."],
			"@/*": ["./*"],
			"~": ["."],
			"~/*": ["./*"]
		}
	},
	"include": ["**/*", ".wxt/wxt.d.ts"],
	"exclude": [".output"]
}
