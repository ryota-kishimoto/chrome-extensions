{
	"name": "uncheck-viewed",
	"version": "1.0.2",
	"private": true,
	"description": "Uncheck all Viewed files on GitHub PR Files Changed tab",
	"scripts": {
		"dev": "wxt",
		"build": "wxt build && cp .output/chrome-mv3/content-scripts/github-pr.js ~/.chrome/extensions/uncheck-viewed/content-scripts/github-pr.js && cp .output/chrome-mv3/content-scripts/github-pr.css ~/.chrome/extensions/uncheck-viewed/content-scripts/github-pr.css",
		"postinstall": "wxt prepare"
	},
	"devDependencies": {
		"typescript": "^5.7.0",
		"wxt": "^0.19.0"
	}
}
